POSTGRES_DB=evolution
POSTGRES_USER=evolution
POSTGRES_PASSWORD=evolution

# Preencha estas 2 chaves externas antes de subir a stack
EVOLUTION_API_KEY=troque-por-uma-chave-forte-da-evolution
MISTRAL_API_KEY=troque-por-uma-chave-forte-da-mistral

# Credenciais de administração do Node-RED
NODE_RED_ADMIN_USER=admin
NODE_RED_ADMIN_PASSWORD=troque-por-uma-senha-unica-e-forte

# Segredos internos
WEBHOOK_SECRET=troque-por-um-token-legado-forte
WEBHOOK_SECRET_PREVIOUS=
WEBHOOK_HMAC_SECRET=troque-por-um-segredo-hmac-forte
WEBHOOK_HMAC_SECRET_PREVIOUS=
WEBHOOK_SIGNATURE_MAX_AGE_MS=300000
NODE_RED_CREDENTIAL_SECRET=troque-por-um-segredo-de-credenciais
NODE_RED_COOKIE_SECRET=troque-por-um-segredo-de-cookie
NODE_RED_ALLOWED_ORIGINS=http://localhost:1880,http://127.0.0.1:1880
NODE_RED_LOGIN_RATE_LIMIT_WINDOW_MS=900000
NODE_RED_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
NODE_RED_LOGIN_RATE_LIMIT_BLOCK_MS=1800000
