  {
    "id": "crm_fn_validate_hmac",
    "type": "function",
    "z": "crm_tab_unificado",
    "name": "Valida Assinatura HMAC",
    "func": "const crypto = require('crypto');\nconst headerSig = msg.req?.headers?.['x-webhook-signature'] || '';\nconst raw = typeof msg.payload === 'string' ? msg.payload : JSON.stringify(msg.payload || {});\nconst secret = env.get('WEBHOOK_HMAC_SECRET') || '';\nif (!secret) {\n  msg.statusCode = 500;\n  msg.payload = { ok: false, error: 'WEBHOOK_HMAC_SECRET ausente' };\n  return [null, msg];\n}\nconst expected = crypto.createHmac('sha256', secret).update(raw).digest('hex');\nif (headerSig !== expected) {\n  msg.statusCode = 401;\n  msg.payload = { ok: false, error: 'assinatura_invalida' };\n  return [null, msg];\n}\nreturn [msg, null];",
    "outputs": 2,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [
      {
        "var": "crypto",
        "module": "crypto"
      }
    ],
    "x": 430,
    "y": 100,
    "wires": [
