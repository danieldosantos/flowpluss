  {
    "id": "crm_fn_prep_kpi_operacao",
    "type": "function",
    "z": "crm_tab_unificado",
    "name": "Prep query KPI Operação",
    "func": "msg.topic = \"SELECT COUNT(*) FILTER (WHERE created_at::date = current_date) AS atendimentos_hoje, COUNT(*) FILTER (WHERE status = 'em_atendimento_humano') AS em_atendimento_humano, COUNT(*) FILTER (WHERE status = 'aguardando_pagamento') AS aguardando_pagamento FROM atendimentos\";\nmsg.payload = [];\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 210,
    "y": 60,
    "wires": [
      [
        "crm_pg_kpis_operacao"
      ]
    ]
  },
  {
    "id": "crm_fn_prep_kpi_vendas",
    "type": "function",
    "z": "crm_tab_unificado",
    "name": "Prep query KPI Vendas",
    "func": "msg.topic = \"SELECT COUNT(*) FILTER (WHERE created_at::date = current_date) AS pedidos_hoje, COALESCE(SUM(total) FILTER (WHERE created_at::date = current_date),0) AS faturamento_hoje, COALESCE(AVG(total) FILTER (WHERE created_at::date = current_date),0) AS ticket_medio FROM pedidos\";\nmsg.payload = [];\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 200,
    "y": 420,
    "wires": [
      [
        "crm_pg_kpis_vendas"
      ]
    ]
  },
  {
    "id": "crm_fn_prep_kpi_financeiro",
    "type": "function",
    "z": "crm_tab_unificado",
    "name": "Prep query KPI Financeiro",
    "func": "msg.topic = \"SELECT COUNT(*) FILTER (WHERE status = 'aguardando_pagamento') AS aguardando_pix, COUNT(*) FILTER (WHERE status = 'pago' AND updated_at::date = current_date) AS pagos_hoje, COALESCE(SUM(total) FILTER (WHERE status = 'pago' AND updated_at::date = current_date),0) AS recebido_hoje FROM pedidos\";\nmsg.payload = [];\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 220,
    "y": 720,
    "wires": [
      [
        "crm_pg_kpis_financeiro"
      ]
    ]
  },
