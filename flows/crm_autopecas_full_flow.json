  {
    "id": "crm_fn_valida_dados_minimos",
    "type": "function",
    "z": "crm_tab_unificado",
    "name": "Valida dados mínimos",
    "func": "const leadAtual = (msg.payload && msg.payload[0]) || {};\nconst crm = msg.crm || {};\nconst merged = {\n  telefone: crm.telefone,\n  nome: crm.nome || leadAtual.nome || null,\n  empresa: crm.empresa || leadAtual.empresa || null,\n  itens_interesse: crm.itens_interesse || leadAtual.itens_interesse || null,\n  estado: crm.estado || leadAtual.estado || null,\n  cidade: crm.cidade || leadAtual.cidade || null\n};\nconst completo = Boolean(merged.nome && merged.itens_interesse);\nconst status = completo ? 'lead_qualificado_bot' : 'dados_incompletos';\nflow.set('ctx:' + merged.telefone, merged);\nmsg.crm = merged;\nmsg.crm.status = status;\nmsg.topic = `INSERT INTO leads (telefone, nome, empresa, itens_interesse, estado, cidade, origem, status)\nVALUES ($1,$2,$3,$4::jsonb,$5,$6,'whatsapp',$7)\nON CONFLICT (telefone) DO UPDATE SET\nnome = EXCLUDED.nome,\nempresa = EXCLUDED.empresa,\nitens_interesse = EXCLUDED.itens_interesse,\nestado = EXCLUDED.estado,\ncidade = EXCLUDED.cidade,\nstatus = EXCLUDED.status,\nupdated_at = now()\nRETURNING *`;\nmsg.payload = [merged.telefone, merged.nome, merged.empresa, JSON.stringify(merged.itens_interesse || []), merged.estado, merged.cidade, status];\nreturn [msg, completo ? null : msg];",
    "outputs": 2,
