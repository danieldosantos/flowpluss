  {
    "id": "crm_fn_format_fila",
    "type": "function",
    "z": "crm_tab_unificado",
    "name": "Formata fila para dashboard",
    "func": "const rows = Array.isArray(msg.payload) ? msg.payload : [];\nif (!rows.length) {\n  msg.payload = '<p>Nenhum atendimento pendente no momento.</p>';\n  return msg;\n}\nconst htmlRows = rows.map(r => `<tr><td>${r.id}</td><td>${r.cliente}</td><td>${r.vendedor}</td><td>${r.status}</td><td>${r.criado_em}</td></tr>`).join('');\nmsg.payload = `<table style=\"width:100%;border-collapse:collapse\"><thead><tr><th>ID</th><th>Cliente</th><th>Vendedor</th><th>Status</th><th>Criado em</th></tr></thead><tbody>${htmlRows}</tbody></table>`;\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 950,
    "y": 1180,
    "wires": [
      [
        "crm_ui_template_fila"
      ]
    ]
  },
