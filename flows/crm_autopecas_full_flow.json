  {
    "id": "crm_fn_normaliza_msg",
    "type": "function",
    "z": "crm_tab_unificado",
    "name": "Normaliza Mensagem + contexto",
    "func": "const body = msg.payload || {};\nconst telefone = String(body.telefone || body.from || '').replace(/\\D/g, '');\nconst texto = String(body.mensagem || body.text || '').trim();\nconst conversa = flow.get('ctx:' + telefone) || {};\nmsg.crm = {\n  telefone,\n  texto,\n  nome: conversa.nome || body.nome || null,\n  empresa: conversa.empresa || body.empresa || null,\n  itens_interesse: conversa.itens_interesse || body.itens_interesse || null,\n  estado: conversa.estado || body.estado || null,\n  cidade: conversa.cidade || body.cidade || null\n};\nmsg.topic = 'SELECT * FROM leads WHERE telefone = $1 LIMIT 1';\nmsg.payload = [telefone];\nreturn msg;",
    "outputs": 1,
    "x": 710,
    "y": 100,
    "wires": [
