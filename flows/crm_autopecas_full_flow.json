    "z": "crm_tab_unificado",
    "name": "Prep query KPI Clientes/Estoque",
    "func": "msg.topic = \"SELECT (SELECT COUNT(*) FROM leads WHERE created_at::date = current_date) AS novos_leads_hoje, (SELECT COUNT(*) FROM leads WHERE status = 'lead_qualificado_bot') AS leads_qualificados, (SELECT COUNT(*) FROM estoque WHERE ativo = true AND quantidade_disponivel <= 5) AS itens_estoque_baixo\";\nmsg.payload = [];\nreturn msg;",
