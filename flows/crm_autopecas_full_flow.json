    "id": "crm_fn_abre_atendimento",
    "type": "function",
    "z": "crm_tab_unificado",
    "name": "Abre atendimento + status",
    "func": "const rows = msg.payload || [];\nif (!rows.length) {\n  node.error('Nenhum vendedor ativo', msg);\n  return null;\n}\nlet idx = flow.get('vendedor_rr_idx') || 0;\nconst vendedor = rows[idx % rows.length];\nflow.set('vendedor_rr_idx', (idx + 1) % rows.length);\nconst leadId = (msg.payload_lead && msg.payload_lead.id) || (msg.crm_lead && msg.crm_lead.id) || (msg.crm && msg.crm.id) || null;\nmsg.crm_vendedor = vendedor;\nmsg.topic = `INSERT INTO atendimentos (lead_id, vendedor_id, status, canal, observacoes) VALUES ($1,$2,'transferido_vendedor','whatsapp',$3) RETURNING *`;\nmsg.payload = [leadId, vendedor.id, 'Auto-roteamento via round-robin'];\nreturn msg;",
