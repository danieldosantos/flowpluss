  {
    "id": "crm_fn_prep_fila_atendimento",
    "type": "function",
    "z": "crm_tab_unificado",
    "name": "Prep query fila atendimento",
    "func": "msg.topic = `SELECT a.id, COALESCE(l.nome,'Lead sem nome') AS cliente, COALESCE(v.nome,'Sem vendedor') AS vendedor, a.status, to_char(a.created_at,'DD/MM HH24:MI') AS criado_em\nFROM atendimentos a\nLEFT JOIN leads l ON l.id = a.lead_id\nLEFT JOIN vendedores v ON v.id = a.vendedor_id\nWHERE a.status IN ('transferido_vendedor','em_atendimento_humano','lead_qualificado_bot')\nORDER BY a.created_at DESC\nLIMIT 30`;\nmsg.payload = [];\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 430,
    "y": 1180,
    "wires": [
      [
        "crm_pg_fila_atendimento"
      ]
    ]
  },
