    "id": "crm_pg_fila_atendimento",
    "type": "postgres",
    "z": "crm_tab_unificado",
    "postgresdb": "crm_postgres_config",
    "name": "Query fila atendimento",
    "output": true,
    "perrow": false,
    "query": "",
    "x": 700,
