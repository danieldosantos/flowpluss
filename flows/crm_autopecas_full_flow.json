    "func": "const txid = msg.payload?.txid || msg.payload?.id;\nconst copia = msg.payload?.pix_copia_cola || msg.payload?.copiaecola;\nconst pedidoId = msg.pedido?.id;\nmsg.topic = `UPDATE pedidos SET pix_txid=$1, pix_copia_cola=$2, status='aguardando_pagamento', updated_at=now() WHERE id=$3 RETURNING *`;\nmsg.payload = [txid, copia, pedidoId];\nmsg.pix = { txid, copia };\nreturn msg;",
